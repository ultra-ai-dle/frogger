# Server-side AI provider keys (do not expose to client)
# Use one or both depending on which provider you wire in app/api routes.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional model overrides
ANALYZE_MODEL=gemini-1.5-flash
EXPLAIN_MODEL=gemini-1.5-flash
# Provider-specific overrides (recommended when using fallback)
ANALYZE_MODEL_GEMINI=gemini-1.5-flash
ANALYZE_MODEL_OPENAI=gpt-4o-mini
EXPLAIN_MODEL_GEMINI=gemini-1.5-flash
EXPLAIN_MODEL_OPENAI=gpt-4o-mini
