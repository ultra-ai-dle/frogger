# Server-side AI provider keys (do not expose to client)
# Use one or both depending on which provider you wire in app/api routes.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional model overrides
ANALYZE_MODEL=gemini-1.5-flash
EXPLAIN_MODEL=gemini-1.5-flash

# Optional runtime behavior flags
# Set to "1" to force mock mode in API routes (if you add this condition later).
PROVA_MOCK_AI=0
